# =========================================================
#  ADAPTIVE FLOW - USER MATERIAL PROFILES
# =========================================================
#  Copy this file to material_profiles_user.cfg to add custom materials.
#  Your material_profiles_user.cfg will NEVER be overwritten by updates.
#
#  To create a custom profile:
#    1. Copy an existing profile from material_profiles_defaults.cfg
#    2. Rename to [gcode_macro _AF_PROFILE_YOURMATERIAL]
#    3. Adjust the values
#    4. Pass MATERIAL=YOURMATERIAL from your slicer
#
#  HEATER WATTAGE AUTO-SCALING:
#  ----------------------------
#  These defaults are tuned for 40W heaters. When sc_heater_wattage is
#  set higher, flow_k, ramp_rise, max_boost, and speed_boost_k are
#  automatically scaled at runtime. No manual overrides needed.
#
#  HF NOZZLE AUTO-COMPENSATION:
#  ----------------------------
#  default_pa values are tuned for Standard nozzles. When
#  use_high_flow_nozzle is True, PA is auto-scaled by hf_pa_scale (1.4x)
#  and smooth_time is auto-set to hf_smooth_time. No overrides needed.
#
#  PARAMETER GUIDE:
#  ----------------
#  flow_k:         Temp boost per mm³/s of flow (higher = more aggressive)
#  speed_boost_k:  Temp boost per mm/s above 100mm/s (for thin walls at speed)
#  max_boost:      Maximum temperature boost cap (°C above base)
#  max_temp:       Absolute maximum temperature limit (safety)
#  flow_gate:      Minimum flow (mm³/s) before boost activates (HF nozzle)
#  flow_gate_std:  Minimum flow (mm³/s) before boost activates (Standard nozzle)
#  pa_boost_k:     PA reduction per °C of boost (viscosity compensation)
#  ramp_rise:      How fast temp can increase (°C/s)
#  ramp_fall:      How fast temp can decrease (°C/s)
#  default_pa:     Default PA if user hasn't calibrated (Standard nozzle base)
#  sc_flow_gate:   Smart cooling flow threshold (mm³/s)
#  sc_flow_k:      Fan reduction per mm³/s above sc_flow_gate
#  sc_min_fan:     Minimum fan speed (0.0-1.0)
#  sc_max_fan:     Maximum fan speed (0.0-1.0) — absolute ceiling
# =========================================================

# Example: Custom PLA variant
# [gcode_macro _AF_PROFILE_MYPLA]
# variable_flow_k: 0.50            # 40W base (auto-scaled by heater wattage)
# variable_speed_boost_k: 0.06
# variable_max_boost: 12.0         # 40W base (auto-scaled by heater wattage)
# variable_max_temp: 245
# variable_flow_gate: 12.0
# variable_flow_gate_std: 8.0
# variable_pa_boost_k: 0.0008
# variable_ramp_rise: 2.5          # 40W base (auto-scaled by heater wattage)
# variable_ramp_fall: 1.5
# variable_default_pa: 0.032       # Standard nozzle base (HF auto-scales to 0.045)
# variable_sc_flow_gate: 8.0
# variable_sc_flow_k: 0.02
# variable_sc_min_fan: 0.50
# variable_sc_max_fan: 1.00
# gcode:

# Example: Custom PETG variant
# [gcode_macro _AF_PROFILE_MYPETG]
# variable_flow_k: 0.50            # 40W base (auto-scaled by heater wattage)
# variable_speed_boost_k: 0.06
# variable_max_boost: 15.0         # 40W base (auto-scaled by heater wattage)
# variable_max_temp: 280
# variable_flow_gate: 12.0
# variable_flow_gate_std: 8.0
# variable_pa_boost_k: 0.0008
# variable_ramp_rise: 3.0          # 40W base (auto-scaled by heater wattage)
# variable_ramp_fall: 1.5
# variable_default_pa: 0.040       # Standard nozzle base (HF auto-scales to 0.056)
# variable_sc_flow_gate: 10.0
# variable_sc_flow_k: 0.02
# variable_sc_min_fan: 0.15
# variable_sc_max_fan: 0.40
# gcode:
