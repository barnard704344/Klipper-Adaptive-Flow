# =============================================================================
# PRINT_START / PRINT_END — Voron 2.4 / Trident template for Adaptive Flow
# =============================================================================
#
# HOW TO USE
# ----------
# 1. Copy the macros below into your printer.cfg (or a [include] file).
# 2. Search for "# >>> EDIT" — those are the ONLY lines you need to change.
# 3. Set your slicer's Start G-code to:
#      PRINT_START BED=[first_layer_bed_temperature] EXTRUDER=[first_layer_temperature] MATERIAL={filament_type[0]}
# 4. Set your slicer's End G-code to:
#      PRINT_END
#
# IMPORTANT: Disable Pressure Advance in your slicer — Adaptive Flow handles it.
#   PrusaSlicer/OrcaSlicer: Printer Settings → Custom G-code → remove any SET_PRESSURE_ADVANCE
#   Cura: Remove any SET_PRESSURE_ADVANCE from start g-code
#   SuperSlicer: Printer Settings → Firmware → disable "use firmware PA"
#
# PREREQUISITES
# -------------
# This template assumes:
#   - _CG28 (conditional home) macro — replace with G28 if you don't have one
#   - QUAD_GANTRY_LEVEL — remove or swap for Z_TILT_ADJUST on Trident
#   - SFS_T0 filament sensor — remove the two SET_FILAMENT_SENSOR lines if unused
#   - rapid_scan bed mesh — change to default METHOD if your probe doesn't support it
#
# =============================================================================


# ─────────────────────────────────────────────────────────────
#  PRINT_START — Voron 2.4
# ─────────────────────────────────────────────────────────────
[gcode_macro PRINT_START]
gcode:
    {% set BED = params.BED|default(60)|int %}
    {% set EXTRUDER = params.EXTRUDER|default(200)|int %}
    {% set x_max = printer.toolhead.axis_maximum.x|float %}
    {% set y_max = printer.toolhead.axis_maximum.y|float %}
    {% set x_min = printer.toolhead.axis_minimum.x|float %}
    {% set y_min = printer.toolhead.axis_minimum.y|float %}
    {% set x_mid = (x_max + x_min) / 2.0 %}
    {% set y_mid = (y_max + y_min) / 2.0 %}

    # >>> EDIT: Remove or change to ENABLE=0 if you don't have a filament sensor.
    SET_FILAMENT_SENSOR SENSOR=SFS_T0 ENABLE=1

    # ── Stage 1: Home & heat bed ──────────────────────────────
    M140 S{BED}                  # Start heating bed
    M104 S150                    # Preheat nozzle to 150 °C
    _CG28                        # Conditional home (replace with G28 if needed)
    G90
    G1 Z20 F9000
    G1 X{x_mid} Y{y_mid} F12000
    M190 S{BED}                  # Wait for bed

    # ── Stage 2: Levelling & mesh ─────────────────────────────
    QUAD_GANTRY_LEVEL            # >>> EDIT: Use Z_TILT_ADJUST for Trident
    G28 Z                        # Re-home Z after QGL

    BED_MESH_CLEAR
    # >>> EDIT: Remove METHOD=rapid_scan if your probe doesn't support it.
    BED_MESH_CALIBRATE METHOD=rapid_scan ADAPTIVE=1
    G1 X{x_mid} Y{y_mid} Z10 F12000

    # ── Stage 3: Heat nozzle ──────────────────────────────────
    M109 S{EXTRUDER}             # Wait for nozzle

    # ── Stage 4: Purge ────────────────────────────────────────
    # Double purge line along the front edge. Adjust coordinates for your bed.
    G90
    G92 E0
    G1 X{(x_min + 30) if (x_min + 30) > 30 else 30} Y{y_min + 5} Z0.3 F12000
    G91
    G1 X220 E18 F1200
    G1 Y1 F6000
    G1 X-220 E9 F1200
    G90
    G92 E0

    # ── Stage 5: Adaptive Flow ────────────────────────────────
    # Do NOT edit this line — it activates the system using your slicer's material.
    AT_START MATERIAL={params.MATERIAL}


# ─────────────────────────────────────────────────────────────
#  PRINT_END — Voron 2.4
# ─────────────────────────────────────────────────────────────
[gcode_macro PRINT_END]
gcode:
    # Save learned Speed Guard values and disable Adaptive Flow
    AT_END

    # >>> EDIT: Remove if you don't have a filament sensor.
    SET_FILAMENT_SENSOR SENSOR=SFS_T0 ENABLE=0

    TURN_OFF_HEATERS
    M107

    # Safe retract & Z raise
    {% set max_z = printer.toolhead.axis_maximum.z|float %}
    {% set cur_z = printer.toolhead.position.z|float %}
    {% set z_hop = [20.0, max_z - cur_z]|min %}
    G91
    G1 E-5 F3600
    G0 Z{z_hop} F3600
    G90

    # Park at rear corner
    G0 X{printer.toolhead.axis_maximum.x - 10} Y{printer.toolhead.axis_maximum.y - 10} F12000

    # Motors off (keep Z engaged)
    M84 X Y E
