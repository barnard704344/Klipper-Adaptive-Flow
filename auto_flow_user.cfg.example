# =========================================================
#  ADAPTIVE FLOW - USER CONFIGURATION OVERRIDES
# =========================================================
#  Copy this file to auto_flow_user.cfg to customize settings.
#  Your auto_flow_user.cfg will NEVER be overwritten by updates.
#
#  Uncomment and edit any variables you want to override.
#  All other values come from auto_flow_defaults.cfg automatically.
# =========================================================

[gcode_macro _AUTO_TEMP_CORE]
# HOTEND TYPE (Revo Only)
# Set to True for Revo HF, False for Revo Standard/Micro
variable_use_high_flow_nozzle: True

# HEATER WATTAGE
# 40 = stock Revo, 60 = upgrade. Material profiles auto-scale.
# variable_sc_heater_wattage: 40

# HF MELT ZONE COMPENSATION (uncomment to override)
# HF nozzles have ~2.3x more melt zone volume than Standard.
# PA is auto-scaled and smooth_time auto-set based on nozzle type.
# variable_hf_pa_scale: 1.40       # PA multiplier for HF nozzles
# variable_hf_smooth_time: 0.060   # PA smooth_time for HF (seconds)
# variable_sf_smooth_time: 0.040   # PA smooth_time for Standard (seconds)
# variable_hf_temp_offset: 5.0     # Extra temp offset for HF nozzles (°C)

# FLOW SMOOTHING (uncomment to override)
# 0.35 = quality-focused (less jitter), 0.15 = faster response
# variable_flow_smoothing: 0.35

# DYNAMIC PRESSURE ADVANCE (uncomment to override)
# variable_pa_enable: True
# variable_pa_deadband: 0.003      # Min PA change before issuing command
# variable_pa_min_value: 0.010     # Absolute minimum PA allowed
# variable_pa_max_reduction: 0.020 # Max PA reduction from base value

# SPEED-BASED BOOST (uncomment to override)
# variable_speed_boost_threshold: 100.0
# variable_speed_boost_k: 0.08

# THERMAL SAFETY (uncomment to override)
# variable_thermal_runaway_threshold: 15.0
# variable_thermal_undertemp_threshold: 10.0

# FIRST LAYER MODE (uncomment to override)
# variable_first_layer_skip: True
# variable_first_layer_height: 0.3

# FILAMENT CROSS-SECTION (uncomment to override)
# Default 2.405 mm² for 1.75mm filament. Change for 2.85mm (6.382)
# variable_filament_cross_section: 2.405

# MULTI-OBJECT TEMPERATURE MANAGEMENT (uncomment to override)
# variable_multi_object_temp_wait: True
# variable_temp_wait_tolerance: 5.0

# FLOW RATE SAFETY LIMITS (uncomment to override)
# variable_max_safe_flow_hf: 25.0   # Max flow for Revo HF nozzles (mm³/s)
# variable_max_safe_flow_std: 15.0  # Max flow for Revo Std nozzles (mm³/s)

# DYNAMIC Z-WINDOW LEARNING (uncomment to override)
# variable_dynz_enable: True
# variable_dynz_bin_height: 2.0
# variable_dynz_speed_thresh: 80.0
# variable_dynz_flow_max: 8.0
# variable_dynz_pwm_thresh: 0.70
# variable_dynz_score_inc: 1.0
# variable_dynz_score_decay: 0.90
# variable_dynz_activate_score: 6.0
# variable_dynz_deactivate_score: 1.5
# variable_dynz_accel_relief: 3200
# variable_dynz_relief_method: 'temp_reduction'
# variable_dynz_temp_reduction: 8.0
# variable_dynz_base_accel: 0

# SMART COOLING (uncomment to override)
# SC takes full control of the fan. Set slicer min/max fan to 0%.
# Bridge/overhang fan from slicer is still respected, but sc_max_fan
# is the absolute ceiling — slicer cannot exceed it.
# variable_sc_enable: True
# variable_sc_flow_gate: 8.0
# variable_sc_flow_k: 0.03
# variable_sc_short_layer_time: 12.0
# variable_sc_layer_time_k: 0.01
# variable_sc_min_fan: 0.20
# variable_sc_max_fan: 1.00
# variable_sc_first_layer_fan: 0.0

# HEATER-ADAPTIVE FAN CONTROL (uncomment to override)
# variable_sc_heater_adaptive: True
# variable_sc_heater_duty_threshold: 0.90
# variable_sc_heater_duty_k: 1.0

# IMPORTANT: Do NOT add a "gcode:" line here!
# This section MERGES with the defaults. Adding "gcode:" would replace
# the entire core logic with nothing, breaking adaptive flow.
